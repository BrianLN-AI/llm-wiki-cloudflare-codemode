{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llm-wiki",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],

  // Static assets served by Cloudflare Workers Assets (public/ directory)
  "assets": {
    "directory": "public",
    "not_found_handling": "single-page-application",
    // Worker handles all API, agent and MCP routes; everything else goes to static assets
    "run_worker_first": ["/wiki/*", "/agents/*", "/health"]
  },

  // Durable Objects
  "durable_objects": {
    "bindings": [
      { "name": "WikiAgent",   "class_name": "WikiAgent"   },
      { "name": "IngestAgent", "class_name": "IngestAgent" },
      { "name": "LintAgent",   "class_name": "LintAgent"   }
    ]
  },
  // v1: WikiAgent gets SQLite storage; IngestAgent/LintAgent are stateless DOs
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["WikiAgent"] },
    { "tag": "v2", "new_classes": ["IngestAgent", "LintAgent"] }
  ],

  // R2: raw document storage
  "r2_buckets": [
    { "binding": "RAW_DOCS", "bucket_name": "llm-wiki-raw" }
  ],

  // Vectorize: semantic search index (384 dimensions for bge-small-en-v1.5)
  "vectorize": [
    { "binding": "WIKI_VECTORS", "index_name": "llm-wiki-vectors" }
  ],

  // Workers AI: LLM + embeddings
  "ai": { "binding": "AI" },

  // Dynamic Worker Loader: isolated sandboxes for LLM-generated code
  "worker_loaders": [
    { "binding": "LOADER" }
  ],

  // Observability (logs in Cloudflare dashboard)
  "observability": { "enabled": true },

  // Scheduled triggers: daily wiki lint at 03:00 UTC
  "triggers": {
    "crons": ["0 3 * * *"]
  }
}
