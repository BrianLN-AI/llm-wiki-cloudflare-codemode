{
  "name": "llm-wiki",
  "version": "0.1.0",
  "description": "Karpathy's llm-wiki adapted for Cloudflare Workers — agentic knowledge base with CodeMode and Dynamic Workers",
  "author": "BrianLN-AI",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types env.d.ts --include-runtime false",
    "deploy": "vite build && wrangler deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "*",
    "@cloudflare/codemode": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "agents": "*",
    "ai": "^6.0.149",
    "workers-ai-provider": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "wrangler": "^4.80.0"
  }
}
