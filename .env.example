# Example environment variables for local development
# Copy to .dev.vars for wrangler dev (never commit .dev.vars)

# Override the Workers AI model (optional)
WORKERS_AI_MODEL=@cf/moonshotai/kimi-k2.5

# Public origin of the deployed Worker — used for CDN cache eviction
# Set to your actual workers.dev subdomain or custom domain after deploying
HOST=https://llm-wiki.YOUR_SUBDOMAIN.workers.dev
